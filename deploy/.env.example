# Required
SESSION_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_SECRET=replace-with-a-long-random-string
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=https://chatsc.fayedark.com/api/auth/google/callback
MONGO_USERNAME=replace-with-mongo-username
MONGO_PASSWORD=replace-with-mongo-password
# Bootstrap guarantees this root user exists on fresh and existing volumes.

# Optional
ACCESS_TOKEN_TTL_SECONDS=1800
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_COOKIE_NAME=refresh_token
API_PREFIX=api
AUTH_LOCAL_ENABLED=false
PROCESSOR_REMOTE_HOST=
PROCESSOR_REMOTE_PORT=9191
PROCESSOR_REMOTE_TIMEOUT_MS=5000
CHAT_REVERSE_ENCRYPTION_ENABLED=false
CHAT_REVERSE_ENCRYPTION_SHARED_KEY=
CHAT_REVERSE_ENCRYPTION_HOST=
CHAT_REVERSE_ENCRYPTION_PORT=9191
CHAT_REVERSE_ENCRYPTION_TIMEOUT_MS=5000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
VITE_API_BASE_URL=/api
VITE_AI_ENABLED=true
VITE_AI_SOCKET_NAMESPACE=/ai
GEMINI_API_KEYS=replace-with-comma-separated-api-keys
GEMINI_MODELS=gemini-1.5-flash,gemini-1.5-pro
GEMINI_REQUEST_TIMEOUT_MS=30000
GEMINI_MODERATION_TIMEOUT_MS=5000
GEMINI_SUGGESTION_TIMEOUT_MS=10000
GEMINI_MAX_CONTEXT_MESSAGES=10
AI_CHATBOT_ENABLED=true
AI_SUGGESTIONS_ENABLED=true
AI_MODERATION_ENABLED=true
